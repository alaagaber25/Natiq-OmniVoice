{
    "_comment": "Dialect fine-tune of natiq_v2 from natiq_v1. Prompt-based cloning + language tag, NO instruct/pinyin (the Natiq data has neither field). SDPA recipe, stable on the 20GB RTX 4000 Ada.",

    "llm_name_or_path": "Qwen/Qwen3-0.6B",
    "init_from_checkpoint": "F:/VOOM-AI/GitHubs/TTS/omnivoice-v2/models/natiq_v1",
    "resume_from_checkpoint": null,

    "audio_vocab_size": 1025,
    "audio_mask_id": 1024,
