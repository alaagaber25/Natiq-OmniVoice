    "steps": 15000,
    "seed": 42,
    "lr_scheduler_type": "cosine",
    "warmup_type": "ratio",
    "warmup_ratio": 0.03,

    "batch_tokens": 2048,
    "gradient_accumulation_steps": 4,
    "num_workers": 0,

    "attn_implementation": "sdpa",
    "max_sample_tokens": 2000,
    "min_sample_tokens": 50,
    "max_batch_size": 16,

    "mixed_precision": "bf16",
    "allow_tf32": true,

    "save_steps": 500, "eval_steps": 500, "logging_steps": 25
